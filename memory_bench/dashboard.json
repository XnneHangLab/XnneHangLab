        {
          "id": "ab22ed72-4d6f-40c6-afa7-b2fb4742f127",
          "title": "",
          "query": "WITH 30 AS claimLimit, 3 AS memLimit\n\n// 1) 选一个“证据最丰富”的分支 (Character, Domain, Predicate)\nMATCH (c:Character)-[r1:HAS_DOMAIN]->(d:Domain)-[r2:HAS_PREDICATE]->(p:Predicate)\nWITH c,d,p,r1,r2, claimLimit, memLimit,\n     COUNT { (p)-[:HAS_CLAIM]->(:Claim) } AS claim_cnt,\n     COUNT { (p)-[:HAS_CLAIM]->(:Claim)-[:EVIDENCED_BY]->(:MemoryItem) } AS ev_cnt\nWHERE claim_cnt > 0\nORDER BY ev_cnt DESC, claim_cnt DESC\nLIMIT 1\n\n// 2) 取该 Predicate 下前 claimLimit 条 Claim\nCALL {\n  WITH p, claimLimit\n  MATCH (p)-[r3:HAS_CLAIM]->(cl:Claim)\n  RETURN cl, r3\n  ORDER BY cl.rank ASC, cl.updated_at DESC\n  LIMIT 30\n}\n\n// 3) 每条 Claim 最多取 memLimit 条 MemoryItem\nOPTIONAL MATCH (cl)-[re:EVIDENCED_BY]->(m:MemoryItem)\nWITH c,d,p,cl,r1,r2,r3, memLimit,\n     collect({re:re, m:m})[0..memLimit] AS evs\n\nUNWIND (CASE WHEN evs = [] THEN [null] ELSE evs END) AS ev\nRETURN\n  c, d, p, cl,\n  r1, r2, r3,\n  (CASE WHEN ev IS NULL THEN null ELSE ev.re END) AS re,\n  (CASE WHEN ev IS NULL THEN null ELSE ev.m  END) AS m;",
          "width": 12,
          "height": 8,
          "x": 12,
          "y": 0,
          "type": "graph",
