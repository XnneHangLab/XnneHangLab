          "query": "MATCH (c:Character)\nWITH c, COUNT { (c)-[:HAS_DOMAIN]->() } AS domain_cnt\nWHERE domain_cnt > 0\nORDER BY domain_cnt DESC\nLIMIT 1\nMATCH (c)-[r:HAS_DOMAIN]->(d:Domain)\nRETURN c, r, d\nLIMIT toInteger(coalesce(20, 50));",
