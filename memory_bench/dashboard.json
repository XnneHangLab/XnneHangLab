        {
          "id": "ab22ed72-4d6f-40c6-afa7-b2fb4742f127",
          "title": "memory item in claims",
          "query": "// 1) 自动选择“证据最丰富”的分支：Character -> Domain -> Predicate（只取 1 条分支）\nCALL {\n  MATCH (c:Character)-[r1:HAS_DOMAIN]->(d:Domain)-[r2:HAS_PREDICATE]->(p:Predicate)\n  WITH c, d, p, r1, r2,\n       COUNT { (p)-[:HAS_CLAIM]->(:Claim) } AS claim_cnt,\n       COUNT { (p)-[:HAS_CLAIM]->(:Claim)-[:EVIDENCED_BY]->(:MemoryItem) } AS ev_cnt\n  WHERE claim_cnt > 0\n  ORDER BY ev_cnt DESC, claim_cnt DESC\n  LIMIT 1\n  RETURN c, d, p, r1, r2, claim_cnt, ev_cnt\n}\n\n// 2) 该 Predicate 下取全部 Claim\nMATCH (p)-[r3:HAS_CLAIM]->(cl:Claim)\n\n// 3) 每条 Claim 取全部 evidence MemoryItem（可为空，所以 OPTIONAL）\nOPTIONAL MATCH (cl)-[re:EVIDENCED_BY]->(m:MemoryItem)\n\n// 4) 返回完整链路（Character->Domain->Predicate->Claim->MemoryItem）\nRETURN\n  c, d, p, cl, m,\n  r1, r2, r3, re,\n  claim_cnt, ev_cnt\nORDER BY\n  ev_cnt DESC,\n  cl.rank ASC,\n  cl.updated_at DESC,\n  m.created_at DESC;",
          "width": 12,
          "height": 8,
          "x": 12,
          "y": 0,
          "type": "graph",
