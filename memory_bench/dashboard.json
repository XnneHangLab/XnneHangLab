          "id": "9be43163-1bd9-4d2d-b96e-34c316b755aa",
          "title": "domains in char",
          "query": "MATCH (c:Character)\nWITH c, COUNT { (c)-[:HAS_DOMAIN]->() } AS domain_cnt\nWHERE domain_cnt > 0\nORDER BY domain_cnt DESC\nLIMIT 1\n\nMATCH (c)-[:HAS_DOMAIN]->(d:Domain)\nWITH c, d, COUNT { (d)-[:HAS_PREDICATE]->() } AS pred_cnt\nWHERE pred_cnt > 0\nORDER BY pred_cnt DESC\nLIMIT 1\n\nMATCH pth = (c)-[:HAS_DOMAIN]->(d)-[:HAS_PREDICATE]->(p:Predicate)\nRETURN pth\nLIMIT 20;",
