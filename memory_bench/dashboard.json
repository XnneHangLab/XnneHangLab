        {
          "id": "b1969c83-b5ae-4574-9a80-189d1704d3b8",
          "title": "character in scene",
          "query": "MATCH (c:Character)\nMATCH (s:Scene {id: \"scene:chill_ai_chat\"})\nMERGE (c)-[r:IN_SCENE]->(s)\nWITH s, collect(c) AS characters, collect(r) AS relationships\nORDER BY size(characters) DESC\nLIMIT 1\nUNWIND characters AS c\nUNWIND relationships AS r\nRETURN s, c, r, type(r) AS relationship_type\n",
