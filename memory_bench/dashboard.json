          "title": "claims in predicate",
          "query": "MATCH (c:Character)-[:HAS_DOMAIN]->(d:Domain)-[:HAS_PREDICATE]->(p:Predicate)-[:HAS_CLAIM]->(cl:Claim)\nWITH c, d, p, count(cl) AS claim_cnt\nORDER BY claim_cnt DESC\nLIMIT 1\n\nMATCH pth = (c)-[:HAS_DOMAIN]->(d)-[:HAS_PREDICATE]->(p)-[:HAS_CLAIM]->(cl:Claim)\nRETURN pth\n",
