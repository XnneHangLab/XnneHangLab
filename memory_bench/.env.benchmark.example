# ---- Memory Bench only ----

# Chat / LLM Model
BENCHMARK_LLM_API_KEY=sk-xxxxx
BENCHMARK_LLM_MODEL=gpt-4o-mini
BENCHMARK_LLM_BASE_URL=https://api.openai.com/v1

# Embedding Model
BENCHMARK_EMBEDDING_API_KEY=sk-xxxxx
BENCHMARK_EMBEDDING_MODEL=text-embedding-3-small
BENCHMARK_EMBEDDING_BASE_URL=https://api.openai.com/v1

# LLM rate limit (requests per minute, 0 = unlimited)
BENCHMARK_LLM_RATE_LIMIT=0

# Optional defaults (CLI overrides these)
BENCHMARK_WORKERS=6
BENCHMARK_SOURCE=auto
BENCHMARK_SCENE_ID=chill_ai_chat
BENCHMARK_CHARACTER_ID=congyin

# ---- Memory Chat Server (chat_server.py) ----
# Chat LLM provider for forwarding (defaults to BENCHMARK_LLM_* if not set)
# CHAT_API_KEY=sk-xxxxx
# CHAT_BASE_URL=https://openrouter.ai/api/v1
# CHAT_MODEL=google/gemini-2.0-flash

# Mem0 LLM for memory extraction (defaults to CHAT_* → BENCHMARK_LLM_* if not set)
# MEM0_LLM_API_KEY=sk-xxxxx
# MEM0_LLM_BASE_URL=https://api.openai.com/v1
# MEM0_LLM_MODEL=gpt-4o-mini

# Server auth (if set, clients must send Authorization: Bearer <key>)
# CHAT_SERVER_API_KEY=sk-your-server-key

# Identity
# CHAT_USER_ID=xnne
# CHAT_AGENT_ID=congyin

# ---- Graph Pipeline (--enable-graph) ----
# Claim extraction LLM (defaults to MEM0_LLM_* → CHAT_* if not set)
# CLAIM_LLM_API_KEY=sk-xxxxx
# CLAIM_LLM_BASE_URL=https://api.openai.com/v1
# CLAIM_LLM_MODEL=gpt-4o-mini

# Neo4j (Docker container)
NEO4J_CONTAINER=membench-neo4j-mem0
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j

# Metadata nodes (for realtime graph pipeline)
# These are used to create/update User, Agent, Scene, Character nodes in Neo4j
METADATA_USER_ID=xnne
METADATA_USER_NAME=xnne
METADATA_AGENT_ID=congyin
METADATA_AGENT_NAME=congyin
METADATA_SCENE_ID=chill_ai_chat
METADATA_SCENE_NAME=Chill AI Chat
METADATA_CHARACTER_ID=congyin
METADATA_CHARACTER_NAME=聪音 (Congyin)
