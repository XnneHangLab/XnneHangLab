# API Keys Configuration Example
# Copy this file to .env and fill in your actual API keys

# OpenAI API
OPENAI_API_KEY = ""
OPENAI_API_FORMAT = "chat_completion"

# Lingyi API
LINGYI_API_KEY = ""
LINGYI_API_FORMAT = "chat_completion"

# Gemini API
GEMINI_API_KEY = ""
GEMINI_API_FORMAT = "chat_completion"

# OAIPRO API
OAIPRO_API_KEY = ""
OAIPRO_API_FORMAT = "chat_completion"

# Cerebras API
CEREBRAS_API_KEY = ""
CEREBRAS_API_FORMAT = "chat_completion"

# Qwen Code Plan API
QWEN_CODE_PLAN_API_KEY = ""
QWEN_CODE_PLAN_API_FORMAT = "chat_completion"

# DeepLX API
DEEPLX_API_KEY = ""

# Translation Configuration
TRANSLATE_PROVIDER = "llm"
LLM_TRANSLATE_MODEL_PATH = "./models/qwen2.5-0.5b-instruct-q8_0.gguf"
LLM_TRANSLATE_N_GPU_LAYERS = "0"

# Chat Model Configuration
# Available providers: openai / lingyi / gemini / oaipro / cerebras / qwen-code-plan
CHAT_MODEL_PROVIDER = "cerebras"
CHAT_MODEL_NAME = "zai-glm-4.7"
CHAT_MODEL_SUPPORT_VISION = "false"

# Vision Model Configuration
# Available providers: openai / lingyi / gemini / oaipro / cerebras / qwen-code-plan
VISION_MODEL_PROVIDER = "oaipro"
VISION_MODEL_NAME = "gpt-5.1-2025-11-13"

# Embedding Model Configuration（agent.embedding，供 memory_bench 等插件复用）
EMBEDDING_API_KEY = ""
EMBEDDING_BASE_URL = "https://api.oaipro.com/v1"
EMBEDDING_MODEL = "text-embedding-3-small"

# proxy_router 鉴权（选填，空=不鉴权）
MEMORY_BENCH_SERVER_API_KEY = ""

# ---- Package Switches ----
# true/false 控制 lab.toml 的 [package] 开关，未设置则不覆盖当前值
PKG_MEMORY_BENCH = "false"
PKG_LLM_TRANSLATE = "false"
PKG_QWEN_TTS = "false"
PKG_GPT_SOVITS = "false"
PKG_SHERPA_ASR = "false"
PKG_QWEN_ASR = "false"
