LLM_PROVIDERS_JSON='{
  "providers": [
    {
      "name": "openai",
      "llm_base_url": "https://api.openai.com/v1",
      "llm_api_key": "",
      "api_format": "chat_completion"
    },
    {
      "name": "gemini",
      "llm_base_url": "https://generativelanguage.googleapis.com/v1beta/openai/",
      "llm_api_key": "",
      "api_format": "chat_completion"
    },
    {
      "name": "qwen-code-plan",
      "llm_base_url": "https://api.qwen.ai/v1",
      "llm_api_key": "",
      "api_format": "chat_completion"
    }
  ]
}'

CHAT_MODEL_PROVIDER="openai"
CHAT_MODEL_NAME="gpt-5.1"
CHAT_MODEL_SUPPORT_VISION="false"
CHAT_MODEL_REASONING="true"

VISION_MODEL_PROVIDER="gemini"
VISION_MODEL_NAME="gemini-2.5-pro"
VISION_MODEL_REASONING="true"

TTS_PROVIDER="gpt_sovits"
TTS_GSV_LITE_USE_BERT = "false"
TTS_GENIE_TTS_USE_ROBERTA = "false"


# Local Embedding Configuration
LOCAL_EMBEDDING_MODEL_PATH = "./models/bge-m3-q8_0.gguf"
LOCAL_EMBEDDING_POOLING_TYPE = "mean"
LOCAL_EMBEDDING_N_GPU_LAYERS = "0"

# proxy_router auth (optional, empty = disabled)
MEMORY_BENCH_SERVER_API_KEY = ""

# ---- Package Switches ----
PKG_MEMORY_BENCH = "true"
PKG_LLM_TRANSLATE = "true"
PKG_LOCAL_EMBEDDING = "true"
PKG_QWEN_TTS = "false"
PKG_GSV_LITE = "false"
PKG_GENIE_TTS = "false"
PKG_GPT_SOVITS = "false"
PKG_SHERPA_ASR = "false"
PKG_QWEN_ASR = "false"
