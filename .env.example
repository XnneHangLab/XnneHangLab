# API Keys Configuration Example
# Copy this file to .env and fill in your actual API keys

# OpenAI API
OPENAI_API_KEY=""
OPENAI_API_FORMAT="chat_completion"

# Lingyi API
LINGYI_API_KEY=""
LINGYI_API_FORMAT="chat_completion"

# Gemini API
GEMINI_API_KEY=""
GEMINI_API_FORMAT="chat_completion"

# OAIPRO API
OAIPRO_API_KEY=""
OAIPRO_API_FORMAT="chat_completion"

# Cerebras API
CEREBRAS_API_KEY=""
CEREBRAS_API_FORMAT="chat_completion"

# DeepLX API
DEEPLX_API_KEY=""

# Chat Model Configuration
CHAT_MODEL_PROVIDER="cerebras"
CHAT_MODEL_NAME="zai-glm-4.7"
CHAT_MODEL_SUPPORT_VISION="false"

# Tool Model Configuration
TOOL_MODEL_PROVIDER="oaipro"
TOOL_MODEL_NAME="gpt-4.1-mini"

# Vision Model Configuration
VISION_MODEL_PROVIDER="oaipro"
VISION_MODEL_NAME="gpt-5.1-2025-11-13"

# ---- Memory Bench (package.memory_bench = true) ----
# 以下配置对应 lab.toml 的 [memory_bench] 块，通过 just key 一次性写入。
# embedding 为必填，llm 留空则自动复用 chat_model 配置。

# Embedding model（必填）
MEMORY_BENCH_EMBEDDING_API_KEY=""
MEMORY_BENCH_EMBEDDING_BASE_URL="https://api.oaipro.com/v1"
MEMORY_BENCH_EMBEDDING_MODEL="text-embedding-3-small"

# mem0 事实提取 LLM（选填，空=复用 chat_model）
MEMORY_BENCH_LLM_API_KEY=""
MEMORY_BENCH_LLM_BASE_URL=""
MEMORY_BENCH_LLM_MODEL=""

# proxy_router 鉴权（选填，空=不鉴权）
MEMORY_BENCH_SERVER_API_KEY=""